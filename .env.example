ENVIRONMENT=prod
LOG_LEVEL=INFO
DRIVER=~fastapi+~httpx+~websockets
LOCALSTORE_USE_CWD=true

HOST=0.0.0.0
PORT=8080

ONEBOT_WS_URLS=["ws://127.0.0.1:3001/onebot/v11/ws"]

AI_API_KEY=your-ai-api-key
AI_BASE_URL=http://127.0.0.1:8317/v1

TEXT_MODEL=bytedance-seed/dola-seed-2.0-pro:free
VISION_MODEL=bytedance-seed/dola-seed-2.0-pro:free
TEXT_MODEL_FALLBACK=x-ai/grok-code-fast-1:optimized:free,kilo-auto/free,openrouter/free
VISION_MODEL_FALLBACK=openrouter/free

SERPER_API_KEY=your-serper-api-key
TAVILY_API_KEY=your-tavily-api-key
AMAP_API_KEY=your-amap-api-key

ADMIN_UID=123456789
ADMIN_API_TOKEN=change-this-token
DEFAULT_REPLY_RATE=100

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=change-this-password
MYSQL_DB=xiaomiao

MINECRAFT_API_SECRET=change-this-secret
MINECRAFT_NOTIFY_GROUP=0

BLOCKED_GROUPS=
BLOCKED_USERS=
